    def search_food(self):
        """API 연동을 위한 검색 로직 (현재는 더미 데이터 출력)"""
        keyword = self.search_entry.get()
        if not keyword:
            messagebox.showwarning("입력 오류", "검색할 음식을 입력해주세요.")
            return

        self.result_list.delete(0, tk.END)
        params = {'serviceKey': 'abe7a26a998e4c1da86d5781b6a3313a53554fe7fd8900580222e6ae95efa2d0', 'type': 'json', 'FOOD_NM_KR': keyword, 'numOfRows' : 20}
        url = "https://apis.data.go.kr/1471000/FoodNtrCpntDbInfo02/getFoodNtrCpntDbInq02"
        a = requests.get(url, params=params)
        a = a.json()
        the_food = a['body']['items']
        self.the_food = the_food
        food_names = []

        for i in the_food:
            food_names.append(i['FOOD_NM_KR'])

        # TODO: 각자 만든 API 활용함수를 통해 음식 결과를 반영하세요.
        self.food_list = food_names
        self.num = 0
        for item in self.food_list:
            self.result_list.insert(self.num, food_names[self.num])
            self.num += 1

    def register_food(self):

        selected_indices = self.result_list.curselection()
        if not selected_indices:
            messagebox.showwarning("선택 오류", "검색 목록에서 등록할 음식을 선택해주세요.")
            return

        food_name = self.result_list.get(selected_indices[0])
        amount = int(self.amount_entry.get())
        unit = self.unit_var.get()
        current_food = self.the_food[self.food_list.index(food_name)]
        currentt_food = dict()
        for i in info_dict.keys():
            currentt_food[info_dict[i]] = current_food[i]
        current_food = currentt_food
        a = self.unit_combo.get()
        print(a)
        c = 0
        if a == "%":
            c=100
        elif a == "g":
            c = current_food['영양성분함량기준량'].strip('mL')
            c=c.strip('g')
            c = int(c)

        self.total_nutrients['수분(g)'] += float(current_food['수분(g)'])
        self.total_nutrients['단백질(g)'] += float(current_food['단백질(g)'])
        self.total_nutrients['지방(g)'] += float(current_food['지방(g)'])
        self.total_nutrients['탄수화물(g)'] += float(current_food['탄수화물(g)'])
        self.total_nutrients['나트륨(mg)'] += float(current_food['나트륨(mg)'])
        self.total_nutrients['식이섬유(g)'] += float(current_food['식이섬유(g)'])

        self.tree.set('수분(g)', 'Amount', round(self.total_nutrients['수분(g)'], 1))
        self.tree.set('단백질(g)', 'Amount', round(self.total_nutrients['단백질(g)'], 1))
        self.tree.set('지방(g)', 'Amount', round(self.total_nutrients['지방(g)'], 1))
        self.tree.set('탄수화물(g)', 'Amount', round(self.total_nutrients['탄수화물(g)'], 1))
        self.tree.set('나트륨(mg)', 'Amount', round(self.total_nutrients['나트륨(mg)'], 1))
        self.tree.set('식이섬유(g)', 'Amount', round(self.total_nutrients['식이섬유(g)'], 1))
        # TODO: 선택된 음식의 영양 정보(API 결과)를 가져와서 목표량 Treeview(self.tree)의 데이터를 갱신하는 로직 작성
        messagebox.showinfo("등록 완료", f"[{food_name}] {amount}{unit} 섭취가 기록되었습니다.\n\n* 실제 영양소 누적 계산식은 추후 연동 필요")

