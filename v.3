        style.configure("Header.TLabel", font=("맑은 고딕", 12, "bold"))



    def load_user(self):
        self.user_info = None

        # 파일 없으면 그냥 종료
        if not os.path.exists("record.txt"):
            return

        try:
            with open("record.txt", "r", encoding="utf-8") as f:
                line = f.readline().strip()

                # 파일 비어있으면 종료
                if not line:
                    return

                data = line.split(",")

                # 데이터 개수 이상하면 종료
                if len(data) != 6:
                    return

                self.user_info = {
                    "age": int(data[0]),
                    "gender": data[1],
                    "height": int(data[2]),
                    "weight": int(data[3]),
                    "movement": data[4],
                    "goal": data[5]
                }

        except ValueError:
            messagebox.showwarning(
                "파일 오류",
                "저장된 사용자 정보가 올바르지 않습니다."
            )
