import requests
import pandas as pd
import os

servicekey = os.getenv("KEY")
info_db = pd.read_excel('출력메세지_식품영양성분DB정보.xlsx')
info_dict = dict(info_db[0:][["paramtrNm", "paramtrDc"]].values)
NUTRITIONS=['수분(g)', '단백질(g)', '지방(g)', '탄수화물(g)', '나트륨(mg)', '식이섬유(g)']
def apply_user_settings(self):
    age = self.user_info["age"]
    gender = self.user_info["gender"]
    height = self.user_info["height"]
    weight = self.user_info["weight"]
    movement = self.user_info["movement"]
    weight_change = self.user_info["goal"]

    multi_num = {
        "운동하지 않음": 1.2,
        "일주일에 가끔 운동": 1.35,
        "일주일에 자주 운동": 1.5,
        "매일 운동": 1.75
    }

    plus_num = {
        "감량": -300,
        "유지": 0,
        "증량": 500
    }

    protein = weight * 7 / 5
    fat = weight * 0.9
    water = weight * 35

    proteinKcal = protein * 4
    fatKcal = fat * 9

    if gender == '남성':
        BMR = 10 * weight + 6.25 * height - 5 * age + 5
    else:
        BMR = 10 * weight + 6.25 * height - 5 * age - 161

    tdee = BMR * multi_num[movement]
    target_calorie = tdee + plus_num[weight_change]

    carbKcal = target_calorie - proteinKcal - fatKcal
    carb = carbKcal / 4

    fiber = target_calorie / 1000 * 14

    self.tree.set('수분(g)', 'Standard', int(water))
    self.tree.set('탄수화물(g)', 'Standard', int(carb))
    self.tree.set('지방(g)', 'Standard', int(fat))
    self.tree.set('단백질(g)', 'Standard', int(protein))
    self.tree.set('나트륨(mg)', 'Standard', 2000)
    self.tree.set('식이섬유(g)', 'Standard', int(fiber))


